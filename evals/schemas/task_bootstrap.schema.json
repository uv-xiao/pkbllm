{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Task bootstrap plan",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "invoked_skills": {
      "type": "array",
      "items": { "type": "string" }
    },
    "task_summary": { "type": "string" },
    "clarifying_questions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "selected_skills": {
      "type": "array",
      "items": { "type": "string" }
    },
    "agents_md": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "target_path": { "type": "string" },
        "mode": { "type": "string", "enum": ["full_embed"] },
        "skills": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "required": ["target_path", "mode", "skills"]
    },
    "install": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "agent": { "type": "string" },
        "mode": { "type": "string", "enum": ["copy", "skills-cli", "none"] },
        "skills": {
          "type": "array",
          "items": { "type": "string" }
        },
        "destination_dir": { "type": "string" }
      },
      "required": ["agent", "mode", "skills", "destination_dir"]
    },
    "notes": {
      "type": "array",
      "items": { "type": "string" }
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "required": [
    "invoked_skills",
    "task_summary",
    "clarifying_questions",
    "selected_skills",
    "agents_md",
    "install",
    "notes",
    "warnings"
  ]
}
